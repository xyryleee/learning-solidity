# Wallet private key (no 0x prefix needed). Never commit .env to git.
PRIVATE_KEY=your_private_key_here

# Optional: override RPC URLs (defaults point to Avalanche public RPCs)
# AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
# AVALANCHE_MAINNET_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Optional: for contract verification on Snowtrace
# SNOWTRACE_API_KEY=your_snowtrace_api_key
